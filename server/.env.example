NODE_ENV=development
PORT=5000
# Use service names when running via docker-compose, localhost otherwise
MONGODB_URI=mongodb://mongo:27017/wpsentinel
REDIS_URL=redis://redis:6379
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@wpsentinel.com
CLIENT_URL=http://localhost:3000

# External probe nodes — format: name|url (comma-separated). Leave empty to disable.
# Example: de-cf|https://wp-sentinel-probe.YOUR_ACCOUNT.workers.dev
PROBE_URLS=
PROBE_SECRET=
